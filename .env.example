# 复制为 .env.local 后填入（勿提交 Git）

# 和风天气 Web API Key（天气功能）
VITE_QWEATHER_KEY=你的和风Web_API_KEY

# 和风控制台「设置」中的专用 API Host（新版免费账号必填，开发/生产均需）
# VITE_QWEATHER_PROXY_TARGET=https://xxxx.qweatherapi.com

# 仅本地开发：走 Vite 代理，避免浏览器 CORS
# VITE_QWEATHER_API_BASE=/api/qweather

# AI 大模型：开源版由用户在应用「设置」中自备 API Key（DeepSeek / Gemini / Claude / OpenAI）
# 无需在此配置 DEEPSEEK_API_KEY

# ── 邮箱验证码（注册时发信）────────────────────────────────────
# 未配置时：本地开发只在页面/终端显示验证码，不会发到邮箱
# 配置后：验证码会真实发送到用户填写的邮箱
#
# 163 邮箱示例（SMTP_PASS 填「授权码」，不是登录密码）：
#   登录 mail.163.com → 设置 → POP3/SMTP/IMAP → 开启 SMTP → 获取授权码
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=你的邮箱@163.com
SMTP_PASS=你的163授权码
SMTP_FROM=MyDate <18701863764@163.com>

# 管理后台：填你的注册用户名（多个用英文逗号分隔），仅这些账号可访问 /admin
# ADMIN_USERNAMES=你的用户名

# ── Netlify 部署（在 Netlify 控制台填，不是本地）────────────────
# 后端 API 部署在 Railway 后，把公网地址填到 Netlify 环境变量：
# VITE_API_ORIGIN=https://你的项目.up.railway.app
# Railway 服务端还需设置 CORS_ORIGIN=https://你的站点.netlify.app
